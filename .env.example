# Profile / storage
PROTON_AGENT_PROFILE=default
PROTON_AGENT_DB_PATH=./data/proton-agent.sqlite3

# Proton Mail Bridge (required for mail)
PROTON_AGENT_BRIDGE_HOST=127.0.0.1
PROTON_AGENT_BRIDGE_IMAP_PORT=1143
PROTON_AGENT_BRIDGE_SMTP_PORT=1025
PROTON_AGENT_BRIDGE_USERNAME=bridge-user@example.com
PROTON_AGENT_BRIDGE_PASSWORD=change-me
PROTON_AGENT_BRIDGE_LABEL_PREFIX=Labels
PROTON_AGENT_BRIDGE_ALLOW_INSECURE_LOCALHOST=true

# Radicale / CalDAV (required for calendar)
PROTON_AGENT_RADICALE_BASE_URL=https://calendar.example.com/user/
PROTON_AGENT_RADICALE_USERNAME=calendar-user
PROTON_AGENT_RADICALE_PASSWORD=change-me
PROTON_AGENT_RADICALE_DEFAULT_CALENDAR=default
PROTON_AGENT_RADICALE_ALLOW_INSECURE=false

# Optional public read-only ICS exposure
PROTON_AGENT_ICS_PUBLIC_BASE_URL=https://calendar.example.com/public/

# Optional Linux systemd credentials directory
# CREDENTIALS_DIRECTORY=/run/credentials/proton-agent.service
